&lt;head&gt;
&lt;style&gt;
body { font-family: sans-serif; color: #333333; font-size: 12px; }
.title { color: #2a7d4f; font-size: 20px; font-weight: bold; }
.sub { color: #888888; font-size: 11px; }
table { border-collapse: collapse; width: 100%; font-size: 12px; }
.items td, .items th { border: 1px solid #999999; padding: 6px; }
.items th { background-color: #f0f0f0; }
.right { text-align: right; }
.center { text-align: center; }
.total { font-size: 14px; font-weight: bold; }
.footer { color: #888888; font-size: 10px; text-align: center; }
&lt;/style&gt;
&lt;/head&gt;
&lt;body&gt;
&lt;div class="title"&gt;Halchal Industries&lt;/div&gt;
&lt;div class="sub"&gt;Tax Invoice&lt;/div&gt;
&lt;hr/&gt;
&lt;p&gt;
&lt;b&gt;Invoice Ref:&lt;/b&gt; INV-${property.orderId}&lt;br/&gt;
&lt;b&gt;Date:&lt;/b&gt; ${property.orderDate}&lt;br/&gt;
&lt;b&gt;Status:&lt;/b&gt; ${property.status}
&lt;/p&gt;
&lt;p&gt;
&lt;b&gt;Bill To:&lt;/b&gt;&lt;br/&gt;
${property.customerName}&lt;br/&gt;
${property.deliveryAddress}, ${property.deliveryState} - ${property.deliveryPincode}&lt;br/&gt;
Phone: ${property.customerPhone}
&lt;/p&gt;
&lt;table class="items"&gt;
&lt;tr&gt;
&lt;th&gt;Product&lt;/th&gt;
&lt;th&gt;Qty&lt;/th&gt;
&lt;th&gt;Unit Price&lt;/th&gt;
&lt;th&gt;Discount&lt;/th&gt;
&lt;th&gt;Taxable Value&lt;/th&gt;
&lt;/tr&gt;
&lt;tr&gt;
&lt;td&gt;${property.product}&lt;/td&gt;
&lt;td class="center"&gt;${property.quantity}&lt;/td&gt;
&lt;td class="right"&gt;Rs.${property.unitPrice}&lt;/td&gt;
&lt;td class="center"&gt;${property.discountPercent}%&lt;/td&gt;
&lt;td class="right"&gt;Rs.${property.taxableValue}&lt;/td&gt;
&lt;/tr&gt;
&lt;/table&gt;
&lt;br/&gt;
&lt;table&gt;
&lt;tr&gt;&lt;td class="right"&gt;&lt;b&gt;Taxable Value:&lt;/b&gt;&lt;/td&gt;&lt;td class="right" style="width:120px;"&gt;Rs.${property.taxableValue}&lt;/td&gt;&lt;/tr&gt;
&lt;tr&gt;&lt;td class="right"&gt;&lt;b&gt;GST (${property.gstRate}%):&lt;/b&gt;&lt;/td&gt;&lt;td class="right"&gt;Rs.${property.gstAmount}&lt;/td&gt;&lt;/tr&gt;
&lt;tr&gt;&lt;td class="right total"&gt;Grand Total:&lt;/td&gt;&lt;td class="right total"&gt;Rs.${property.grandTotal}&lt;/td&gt;&lt;/tr&gt;
&lt;/table&gt;
&lt;p&gt;&lt;b&gt;Payment:&lt;/b&gt; ${property.paymentMethod} (${property.paymentStatus})&lt;/p&gt;
&lt;hr/&gt;
&lt;p class="footer"&gt;Thank you for your order - Halchal Industries&lt;/p&gt;
&lt;/body&gt;
&lt;/html&gt;</value>
